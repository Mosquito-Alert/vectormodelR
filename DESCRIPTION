Package: VectorModelR
Title: An R toolkit for sourcing global data and using it to generate mosquito various models
Version: 1.0.0
Authors@R: c(
    person("Otis", "Johnson", email="otis.johnson@upf.edu", role = c("aut", "cre"), comment = c(ORCID = "0009-0009-7229-8751")),
